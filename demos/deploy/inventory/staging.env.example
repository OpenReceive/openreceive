OPENRECEIVE_ENVIRONMENT=staging
OPENRECEIVE_DEMO_MODE=test_nwc
# Server-only OPENRECEIVE_NWC, OPENRECEIVE_STORE, OPENRECEIVE_NAMESPACE,
# optional OPENRECEIVE_SWAP_CONFIG, and referenced provider secrets belong in
# the host secret env file.
OPENRECEIVE_IMAGE_TAG=replace-with-git-sha
OPENRECEIVE_GIT_SHA=replace-with-git-sha
OPENRECEIVE_IMAGE_DIGEST=sha256:replace-with-image-digest
OPENRECEIVE_DEPLOYED_AT=1970-01-01T00:00:00Z
