#!/usr/bin/env bash
set -euo pipefail

demo="${1:-}"
if [[ -z "$demo" ]]; then
  printf 'Usage: %s express-demo|static-demo|nextjs-demo\n' "$0" >&2
  exit 64
fi

case "$demo" in
  express-demo|static-demo|nextjs-demo) ;;
  *)
    printf 'Unknown demo: %s\n' "$demo" >&2
    exit 64
    ;;
esac

: "${OPENRECEIVE_DEPLOY_HOST:?set OPENRECEIVE_DEPLOY_HOST in a private operator environment}"
: "${OPENRECEIVE_IMAGE_TAG:?set OPENRECEIVE_IMAGE_TAG to the tested git SHA tag}"

printf 'Deploy template validated for %s.\n' "$demo"
printf 'Run the private operator wrapper to SSH to OPENRECEIVE_DEPLOY_HOST and apply demos/deploy/stacks/%s.compose.yml.\n' "$demo"
