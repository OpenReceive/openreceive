#!/usr/bin/env bash
set -euo pipefail

demo="${1:-}"
digest="${2:-}"
if [[ -z "$demo" || -z "$digest" ]]; then
  printf 'Usage: %s express-demo|static-demo|nextjs-demo sha256:<digest>\n' "$0" >&2
  exit 64
fi

case "$demo" in
  express-demo|static-demo|nextjs-demo) ;;
  *)
    printf 'Unknown demo: %s\n' "$demo" >&2
    exit 64
    ;;
esac

case "$digest" in
  sha256:*) ;;
  *)
    printf 'Image digest must start with sha256:\n' >&2
    exit 64
    ;;
esac

printf 'Promotion template validated for %s at %s.\n' "$demo" "$digest"
printf 'Record this digest in demos/deploy/manifests/ before operator promotion.\n'
