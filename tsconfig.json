{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "paths": {
      "@openreceive/angular": [
        "packages/js/angular/src/index.ts"
      ],
      "@openreceive/browser": [
        "packages/js/browser/src/index.ts"
      ],
      "@openreceive/browser/country-map": [
        "packages/js/browser/src/country-map.ts"
      ],
      "@openreceive/browser/internal": [
        "packages/js/browser/src/internal.ts"
      ],
      "@openreceive/core": [
        "packages/js/core/src/index.ts"
      ],
      "@openreceive/core/contracts": [
        "packages/js/core/src/contracts.ts"
      ],
      "@openreceive/elements": [
        "packages/js/elements/src/index.ts"
      ],
      "@openreceive/node": [
        "packages/js/node/src/index.ts"
      ],
      "@openreceive/node/cli": [
        "packages/js/node/src/cli.ts"
      ],
      "@openreceive/provider-data": [
        "packages/js/provider-data/src/index.ts"
      ],
      "@openreceive/react": [
        "packages/js/react/src/index.ts"
      ],
      "@openreceive/svelte": [
        "packages/js/svelte/src/index.ts"
      ],
      "@openreceive/testkit": [
        "packages/js/testkit/src/index.ts"
      ],
      "@openreceive/vue": [
        "packages/js/vue/src/index.ts"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "packages/js/**/*.ts",
    "examples/hello-fruit/server/*/src/**/*.ts",
    "examples/hello-fruit/server/*/src/**/*.tsx",
    "examples/hello-fruit/server/*/vite.config.ts"
  ]
}
