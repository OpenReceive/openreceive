{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "packages/js/**/*.ts",
    "examples/hello-fruit/server/*/src/**/*.ts",
    "examples/hello-fruit/server/*/src/**/*.tsx",
    "examples/hello-fruit/server/*/vite.config.ts"
  ]
}
