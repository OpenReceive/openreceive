{
  "name": "openreceive",
  "version": "0.1.0",
  "private": true,
  "description": "OpenReceive v0.1 receive-checkout reference path",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/js/*",
    "examples/hello-fruit/server/*"
  ],
  "scripts": {
    "build:docs": "node tools/docs/build-index.mjs",
    "build:demo": "npm run build -w @openreceive/example-node-express-react && npm run build -w @openreceive/example-static-html-small-api",
    "generate:models": "node tools/codegen/generate-js-models.mjs",
    "check:generated": "node tools/codegen/generate-js-models.mjs --check",
    "scan:client-bundles": "node tools/validate/scan-client-bundles.mjs",
    "test:package-smoke": "node tools/validate/package-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "test:js": "node --test tests/v0.1/*.test.mjs",
    "validate": "node tools/validate/validate-v0.1.mjs",
    "scan:secrets": "node tools/validate/scan-secrets.mjs",
    "test": "npm run validate && npm run scan:secrets",
    "test:ci": "npm test && npm run check:generated && npm run typecheck && npm run test:js && npm run test:package-smoke && npm run build:demo && npm run scan:client-bundles && npm run build:docs && npm run test:live:nwc",
    "test:vectors": "node tools/validate/validate-v0.1.mjs --vectors",
    "test:live:nwc": "node tools/live-nwc-test/index.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "yaml": "^2.9.0"
  }
}
