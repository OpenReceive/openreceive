{
  "name": "openreceive-workspace",
  "version": "0.1.1",
  "private": true,
  "description": "OpenReceive v0.1 receive-checkout reference path",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/js/*",
    "examples/hello-fruit/server/*"
  ],
  "scripts": {
    "build:docs": "node tools/docs/build-index.mjs",
    "build:demo": "npm run build -w @openreceive/example-node-express && npm run build -w @openreceive/example-static-html-small-api && npm run build -w @openreceive/example-nextjs-fullstack",
    "demo": "node --import tsx tools/run-demo.mjs",
    "demo:clear-volumes": "node tools/clear-demo-volumes.mjs",
    "generate:models": "node tools/codegen/generate-js-models.mjs",
    "check:generated": "node tools/codegen/generate-js-models.mjs --check",
    "check:demo-containers": "node tools/validate/check-demo-containers.mjs",
    "check:demo-deploy": "node tools/validate/check-demo-deploy.mjs",
    "check:release": "node tools/validate/check-release-readiness.mjs",
    "check:workflows": "node tools/validate/check-workflows.mjs",
    "build:packages": "npm run build -w @openreceive/core -w @openreceive/provider-data -w @openreceive/browser -w @openreceive/elements -w @openreceive/node -w @openreceive/http -w @openreceive/express -w @openreceive/fastify -w @openreceive/next -w @openreceive/react -w @openreceive/vue -w @openreceive/svelte -w @openreceive/angular -w @openreceive/testkit -w openreceive",
    "release:plan": "node tools/release/npm-release.mjs plan",
    "release:prepare": "node tools/release/npm-release.mjs prepare",
    "release:publish": "node tools/release/npm-release.mjs publish",
    "pretypecheck": "npm run build:packages",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "scan:client-bundles": "node tools/validate/scan-client-bundles.mjs",
    "test:package-smoke": "node tools/validate/package-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "pretest:js": "npm run build:packages",
    "test:js": "node --import tsx --test tests/v0.1/*.test.mjs",
    "test:ruby": "ruby -Ipackages/ruby/openreceive/lib -e 'load \"packages/ruby/openreceive/test/openreceive_test.rb\"' && ruby -Ipackages/ruby/openreceive/lib -Ipackages/ruby/openreceive-server/lib packages/ruby/openreceive-server/test/server_test.rb && ruby -Ipackages/ruby/openreceive/lib -Ipackages/ruby/openreceive-server/lib -Ipackages/ruby/openreceive-rails/lib packages/ruby/openreceive-rails/test/rails_test.rb && ruby -Ipackages/ruby/openreceive/lib -Ipackages/ruby/openreceive-server/lib tools/conformance/ruby-crosslang.rb",
    "test:live:ruby:nwc": "ruby -Ipackages/ruby/openreceive/lib tools/live-nwc-test/ruby-smoke.rb",
    "validate": "node tools/validate/validate-v0.1.mjs",
    "scan:secrets": "node tools/validate/scan-secrets.mjs",
    "test": "npm run validate && npm run scan:secrets",
    "test:ci:core": "npm test && npm run lint && npm run check:generated && npm run typecheck && npm run test:js && npm run test:package-smoke",
    "test:ci:release": "npm run test:ruby && npm run check:demo-containers && npm run check:demo-deploy && npm run check:release && npm run check:workflows && npm run build:demo && npm run scan:client-bundles && npm run build:docs && npm run test:live:nwc",
    "test:ci": "npm run test:ci:core && npm run test:ci:release",
    "test:vectors": "node tools/validate/validate-v0.1.mjs --vectors",
    "test:live:nwc": "node tools/live-nwc-test/index.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@angular/common": "22.0.3",
    "@angular/compiler": "22.0.3",
    "@angular/core": "22.0.3",
    "@angular/platform-browser": "22.0.3"
  },
  "devDependencies": {
    "@angular/core": "22.0.3",
    "@biomejs/biome": "^2.3.8",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
