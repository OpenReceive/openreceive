# Copy to .env for local live wallet smoke tests and Docker demos.
# Do not commit real values.
OPENRECEIVE_NWC=
OPENRECEIVE_WALLET_PROFILE=rizful

# The dockerized Hello Fruit demos build a production image (NODE_ENV=production)
# and use an unauthenticated single-user checkout. The server refuses to start in
# production mode without this explicit opt-in. Safe for local/test demos only;
# never run unauthenticated mode in a real production app.
OPENRECEIVE_ALLOW_UNAUTHENTICATED_DEMO=true
