# Copy to .env for local live wallet smoke tests and Docker demos.
# Do not commit real values.

# Server-only, receive-only NWC code. Never expose this to browser/mobile code,
# logs, screenshots, docs, source maps, or demo assets.
OPENRECEIVE_NWC=

# OpenReceive-owned durable store. Defaults to local-sqlite when omitted.
# local-sqlite creates ./.openreceive/<namespace>.sqlite3 for single-machine
# self-hosting and local demos. Use Postgres for multi-instance deployments.
# OPENRECEIVE_STORE=local-sqlite
# OPENRECEIVE_STORE=postgres://user:pass@host:5432/appdb
# OPENRECEIVE_STORE=sqlite:///abs/path/openreceive.sqlite3
# OPENRECEIVE_STORE=memory:
# Planned schemes, not supported by the current package adapters:
# OPENRECEIVE_STORE=mysql://user:pass@host:3306/appdb
# OPENRECEIVE_STORE=redis://host:6379/0

# Operational namespace for sharing one store across apps/environments.
OPENRECEIVE_NAMESPACE=default

# Optional request-driven status refresh tuning. Defaults are shown here.
OPENRECEIVE_ACTION_LEASE_TTL_SEC=60
OPENRECEIVE_TRANSACTION_SCAN_INTERVAL_SEC=2
OPENRECEIVE_TRANSACTION_SCAN_PAGE_LIMIT=20
OPENRECEIVE_TRANSACTION_SCAN_WINDOW_PADDING_SEC=0
OPENRECEIVE_TRANSACTION_SCAN_TIMEOUT_MS=9000

# Demo-only local defaults.
OPENRECEIVE_WALLET_PROFILE=rizful
OPENRECEIVE_DEMO_MODE=test_nwc
