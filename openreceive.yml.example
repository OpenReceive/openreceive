## OPENRECEIVE_NWC is required. It's how you receive payments.
## Get a NWC Code: https://openreceive.org/get_a_nwc_code_to_receive_payments
OPENRECEIVE_NWC: 

## Swap providers is recommended. Enables customer payments with USDT, USDC, SOL, or ETH
## Set up swap providers: https://openreceive.org/set_up_swap_provider

# swap:
#  providers:
#   - base_url: 
#     key: 
#     secret: 

# -----------------------------------------------------------------------------
# Optional overrides (defaults shown). Omit this whole section unless you need it.
# -----------------------------------------------------------------------------

# OPENRECEIVE_STORE: local-sqlite
# # Or: OPENRECEIVE_STORE: postgres://USER:PASS@HOST:5432/DB
#
# OPENRECEIVE_PRICE_CURRENCIES:
#   - USD
#
#
# logging:
#   enabled: true
#   directory: ./logs
#   filename: openreceive.log
#   max_file_size_mb: 10
#   max_files: 5
#   level: debug
#
# sentry:
#   dsn: ""
#   # environment: production
#   # release: openreceive@0.1.1
