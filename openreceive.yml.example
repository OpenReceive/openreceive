# Copy to openreceive.yml (git-ignored). Holds receive-only NWC and provider secrets.
# Only OPENRECEIVE_NWC and swap.providers are required; everything else has defaults.

OPENRECEIVE_NWC: ""

swap:
  providers:
    - base_url: https://ff.io
      key: ""
      secret: ""

# -----------------------------------------------------------------------------
# Optional overrides (defaults shown). Omit this whole section unless you need it.
# -----------------------------------------------------------------------------
#
# OPENRECEIVE_NAMESPACE: default
# # Store precedence when OPENRECEIVE_STORE is omitted:
# #   1) DATABASE_PRIVATE_URL if postgres://
# #   2) DATABASE_URL if postgres://
# #   3) local-sqlite under .openreceive/ (refused on Heroku/Vercel/etc.)
# OPENRECEIVE_STORE: local-sqlite
# # Or: OPENRECEIVE_STORE: postgres://USER:PASS@HOST:5432/DB
#
# OPENRECEIVE_PRICE_CURRENCIES:
#   - USD
#
# operation:
#   action_lease_ttl_seconds: 60
#   transaction_scan_interval_seconds: 2
#   transaction_scan_page_limit: 25
#   transaction_scan_window_padding_seconds: 0
#   transaction_scan_timeout_ms: 9000
#
# # Also under swap: (alongside providers above)
# #   settlement_attention_seconds: 60
# # Provider id defaults from base_url host (https://ff.io → ff-io).
# # protocol defaults to fixedfloat.
#
# logging:
#   enabled: true
#   directory: ./logs
#   filename: openreceive.log
#   max_file_size_mb: 10
#   max_files: 5
#   level: debug
#
# sentry:
#   dsn: ""
#   # environment: production
#   # release: openreceive@0.1.1
