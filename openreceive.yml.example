# Copy to openreceive.yml for local development.
# Do not commit openreceive.yml; it contains receive-only NWC and provider secrets.

OPENRECEIVE_NWC: ""
OPENRECEIVE_NAMESPACE: default
OPENRECEIVE_STORE: local-sqlite

OPENRECEIVE_PRICE_CURRENCIES:
  - USD

operation:
  action_lease_ttl_seconds: 60
  transaction_scan_interval_seconds: 2
  transaction_scan_page_limit: 25
  transaction_scan_window_padding_seconds: 0
  transaction_scan_timeout_ms: 9000

swap:
  # Seconds before a completed provider order needs support attention if the
  # wallet has not reported settlement.
  settlement_attention_seconds: 60
  providers:
    - id: fixedfloat
      protocol: fixedfloat
      base_url: https://ff.io
      key: ""
      secret: ""
      # invoice_expiry_seconds auto-derives from
      # deposit_window_seconds + settlement_sla_seconds + invoice_expiry_margin_seconds.
      # Omit it (as here) to use the derived floor; set it only to lengthen the window.

logging:
  # Rotating file logs. Every emitted event is written to ./logs as a single
  # timestamped JSON line (secrets are redacted before logging). The whole block
  # can be omitted to use these defaults.
  enabled: true
  directory: ./logs
  filename: openreceive.log
  max_file_size_mb: 10   # rotate once the active file would exceed this size
  max_files: 5           # log files kept (active file plus rotated backups)
  level: debug           # minimum level written: debug | info | warn | error
