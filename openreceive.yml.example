# OpenReceive has no storage section. Set server-only secrets in the environment:
#   OPENRECEIVE_TOKEN_KEYS=2026-07:<32-byte-base64url-key>,previous:<old-key>
nwc: "REPLACE_WITH_RECEIVE_ONLY_NWC"

price_currencies:
  - USD

logging:
  level: info

# Swap providers are optional. Provider credentials are server-only and are sealed into
# opaque recovery tokens; they are never stored by OpenReceive or sent in plaintext.
# swap:
#   providers:
#     - id: fixedfloat
#       protocol: fixedfloat
#       base_url: https://ff.io
#       key: "REPLACE_WITH_PROVIDER_KEY"
#       secret: "REPLACE_WITH_PROVIDER_SECRET"
