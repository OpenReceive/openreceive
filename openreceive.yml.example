# OpenReceive has no storage section and needs no token/signing key.
nwc: "REPLACE_WITH_RECEIVE_ONLY_NWC"

price_currencies:
  - USD

logging:
  level: info

# Swap providers are optional. Provider credentials and per-order swap_data are server-only;
# they are never stored by OpenReceive or sent to browsers.
# swap:
#   providers:
#     - id: fixedfloat
#       protocol: fixedfloat
#       base_url: https://ff.io
#       key: "REPLACE_WITH_PROVIDER_KEY"
#       secret: "REPLACE_WITH_PROVIDER_SECRET"
