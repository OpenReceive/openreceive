<%= turbo_frame_tag "openreceive_invoice_#{invoice.fetch("invoice_id")}" do %>
  <section
    id="openreceive_invoice_<%= invoice.fetch("invoice_id") %>"
    data-openreceive-transaction-state="<%= invoice.fetch("transaction_state") %>"
  >
    <p><strong>Invoice</strong></p>
    <p><code><%= invoice.fetch("invoice") %></code></p>
    <dl>
      <dt>Amount</dt>
      <dd><%= invoice.fetch("amount_msats") %> msats</dd>
      <dt>Status</dt>
      <dd><%= invoice.fetch("transaction_state") %></dd>
    </dl>
  </section>
<% end %>
