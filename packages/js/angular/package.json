{
  "name": "@openreceive/angular",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@openreceive/browser": "0.1.1",
    "@openreceive/elements": "0.1.1"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./checkout-component": "./dist/openreceive-checkout.component.mjs",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target es2022 --out-dir dist --external @angular/core && node ../../../tools/package/copy-static.mjs src dist styles.css openreceive-checkout.component.mjs"
  }
}
