{
  "name": "openreceive",
  "version": "0.1.1",
  "description": "OpenReceive umbrella package for server, browser, UI, provider data, contracts, and CLI.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openreceive": "./bin/openreceive.mjs"
  },
  "dependencies": {
    "@openreceive/browser": "0.1.1",
    "@openreceive/core": "0.1.1",
    "@openreceive/elements": "0.1.1",
    "@openreceive/node": "0.1.1",
    "@openreceive/provider-data": "0.1.1"
  },
  "peerDependencies": {
    "@openreceive/angular": "0.1.1",
    "@openreceive/express": "0.1.1",
    "@openreceive/fastify": "0.1.1",
    "@openreceive/next": "0.1.1",
    "@openreceive/react": "0.1.1",
    "@openreceive/svelte": "0.1.1",
    "@openreceive/vue": "0.1.1"
  },
  "peerDependenciesMeta": {
    "@openreceive/angular": { "optional": true },
    "@openreceive/express": { "optional": true },
    "@openreceive/fastify": { "optional": true },
    "@openreceive/next": { "optional": true },
    "@openreceive/react": { "optional": true },
    "@openreceive/svelte": { "optional": true },
    "@openreceive/vue": { "optional": true }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.js"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.js"
    },
    "./elements": {
      "types": "./dist/elements.d.ts",
      "import": "./dist/elements.js"
    },
    "./provider-data": {
      "types": "./dist/provider-data.d.ts",
      "import": "./dist/provider-data.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node.ts src/browser.ts src/react.ts src/vue.ts src/svelte.ts src/angular.ts src/elements.ts src/provider-data.ts src/contracts.ts src/express.ts src/fastify.ts src/next.ts --format esm --dts --clean --target es2022 --out-dir dist --external @openreceive/angular --external @openreceive/browser --external @openreceive/core --external @openreceive/elements --external @openreceive/express --external @openreceive/fastify --external @openreceive/next --external @openreceive/node --external @openreceive/provider-data --external @openreceive/react --external @openreceive/svelte --external @openreceive/vue"
  },
  "sideEffects": false
}
