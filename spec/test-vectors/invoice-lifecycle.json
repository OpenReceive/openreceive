{
  "schema_version": "0.1.0",
  "transaction_states": [
    "pending",
    "settled",
    "expired",
    "failed",
    "accepted"
  ],
  "workflow_states": [
    "draft",
    "invoice_created",
    "verifying",
    "settlement_action_pending",
    "settlement_action_completed",
    "expiry_pending_verification",
    "expired_closed",
    "failed_closed",
    "cancelled"
  ],
  "allowed_transitions": [
    [
      "draft",
      "invoice_created"
    ],
    [
      "invoice_created",
      "verifying"
    ],
    [
      "verifying",
      "invoice_created"
    ],
    [
      "verifying",
      "settlement_action_pending"
    ],
    [
      "settlement_action_pending",
      "settlement_action_completed"
    ],
    [
      "invoice_created",
      "expiry_pending_verification"
    ],
    [
      "verifying",
      "expiry_pending_verification"
    ],
    [
      "expiry_pending_verification",
      "settlement_action_pending"
    ],
    [
      "expiry_pending_verification",
      "expired_closed"
    ],
    [
      "invoice_created",
      "failed_closed"
    ],
    [
      "verifying",
      "failed_closed"
    ],
    [
      "invoice_created",
      "cancelled"
    ]
  ],
  "invariants": [
    "workflow_state never stores pending, settled, expired, failed, or accepted",
    "transaction_state never stores invoice_created, verifying, settlement_action_pending, settlement_action_completed, expiry_pending_verification, expired_closed, failed_closed, or cancelled",
    "local expires_at alone does not close an invoice",
    "expired_closed requires a matching wallet transaction state from server-side status refresh",
    "frontend state never runs a merchant settlement action",
    "invoice.settled events replay safely"
  ]
}
