{
  "schema_version": "0.1.0",
  "contract": "OpenReceiveInvoiceKvStore",
  "methods": [
    "putIfAbsent",
    "put",
    "get",
    "getByPaymentHash",
    "getByBolt11Invoice",
    "getByIdempotencyScope",
    "listByOrderId",
    "listByCheckoutId",
    "listOpen",
    "getMeta",
    "casMeta"
  ],
  "record_shape": {
    "rev": "non-negative integer",
    "row": "InvoiceStorageRow"
  },
  "meta_shape": {
    "value": "string",
    "rev": "non-negative integer"
  },
  "transaction_scan_cursor_shape": {
    "from": "unix seconds",
    "until": "unix seconds",
    "limit": "positive integer",
    "offset": "non-negative integer",
    "cycle": "non-negative integer",
    "last_page_scanned_at": "unix seconds"
  },
  "certified_v0_1_transports": [
    "memory",
    "postgres",
    "sqlite"
  ],
  "deferred_transport_targets": [
    "mysql",
    "durable_object"
  ],
  "unsupported_transport_targets": [
    "redis",
    "s3",
    "workers_kv"
  ],
  "cases": [
    {
      "name": "putIfAbsent atomic uniqueness conflicts name the collided key",
      "requires": [
        "invoice_id",
        "idempotency_scope",
        "payment_hash",
        "bolt11"
      ]
    },
    {
      "name": "idempotency scope precedence returns replay or conflict before wallet-value conflicts",
      "requires": [
        "getByIdempotencyScope",
        "idempotency_request_hash"
      ]
    },
    {
      "name": "put rejects stale rev and accepts current rev",
      "requires": [
        "put",
        "rev"
      ]
    },
    {
      "name": "casMeta is atomic and rejects stale rev",
      "requires": [
        "getMeta",
        "casMeta"
      ]
    },
    {
      "name": "concurrent identical creates store exactly one invoice for the idempotency scope",
      "requires": [
        "idempotency_scope",
        "getByIdempotencyScope"
      ]
    },
    {
      "name": "listOpen returns only non-terminal records and honors limit",
      "requires": [
        "listOpen",
        "terminal"
      ]
    },
    {
      "name": "secondary indexes stay consistent across create and transition",
      "requires": [
        "getByPaymentHash",
        "getByBolt11Invoice",
        "getByIdempotencyScope"
      ]
    },
    {
      "name": "ownership guard accepts OpenReceive tables and refuses foreign or newer schemas",
      "requires": [
        "owner",
        "schema_version"
      ]
    },
    {
      "name": "global transaction scan gate allows at most one wallet page per interval",
      "requires": [
        "transaction_scan_gate",
        "casMeta"
      ]
    },
    {
      "name": "transaction scan cursor advances offset on full pages",
      "requires": [
        "transaction_scan_cursor",
        "casMeta"
      ]
    },
    {
      "name": "transaction scan cursor resets offset and increments cycle on short pages",
      "requires": [
        "transaction_scan_cursor",
        "casMeta"
      ]
    },
    {
      "name": "transaction scan cursor is not advanced on wallet errors",
      "requires": [
        "transaction_scan_cursor",
        "casMeta"
      ]
    },
    {
      "name": "settlement action lease prevents concurrent execution and recovers expired claims",
      "requires": [
        "action_claimed_at",
        "action_lease_ttl"
      ]
    }
  ]
}
