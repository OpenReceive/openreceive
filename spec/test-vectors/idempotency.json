{
  "schema_version": "0.1.0",
  "canonical_scope": [
    "namespace",
    "operation",
    "idempotency_key"
  ],
  "operations": [
    "invoice.create",
    "invoice.renew"
  ],
  "cases": [
    {
      "name": "same key same request returns original response",
      "namespace": "demo:tenant:alpha",
      "operation": "invoice.create",
      "idempotency_key": "fruit-demo-user-123-order-456",
      "first_request_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "second_request_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "expected": {
        "status": 200,
        "behavior": "return_original_invoice"
      }
    },
    {
      "name": "same key different request returns conflict",
      "namespace": "demo:tenant:alpha",
      "operation": "invoice.create",
      "idempotency_key": "fruit-demo-user-123-order-456",
      "first_request_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "second_request_hash": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "expected": {
        "status": 409,
        "error_code": "CONFLICT"
      }
    },
    {
      "name": "renew scope is separate from create scope",
      "namespace": "demo:tenant:alpha",
      "operation": "invoice.renew",
      "idempotency_key": "fruit-demo-user-123-order-456-renew-1",
      "first_request_hash": "sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "second_request_hash": "sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "expected": {
        "status": 200,
        "behavior": "return_original_renewal_invoice"
      }
    }
  ]
}
