{
  "schema_version": "0.1.0",
  "rule": "Same logical request must produce an identical sha256: idempotency hash in every OpenReceive port.",
  "algorithm": "sha256(canonical_json(request)) with recursively sorted object keys, prefixed 'sha256:'",
  "cases": [
    {
      "name": "flat request keys sorted",
      "request": {
        "order_id": "order-123",
        "amount": {
          "fiat": {
            "currency": "USD",
            "value": "12.34"
          }
        },
        "memo": "Two bananas"
      },
      "canonical_json": "{\"amount\":{\"fiat\":{\"currency\":\"USD\",\"value\":\"12.34\"}},\"memo\":\"Two bananas\",\"order_id\":\"order-123\"}",
      "expected_request_hash": "sha256:93dbee5c44f8e0eb855eb012842d87471005ee3c5e782014bc6ed8974250fd51"
    },
    {
      "name": "key order does not matter",
      "request": {
        "memo": "Two bananas",
        "amount": {
          "fiat": {
            "currency": "USD",
            "value": "12.34"
          }
        },
        "order_id": "order-123"
      },
      "canonical_json": "{\"amount\":{\"fiat\":{\"currency\":\"USD\",\"value\":\"12.34\"}},\"memo\":\"Two bananas\",\"order_id\":\"order-123\"}",
      "expected_request_hash": "sha256:93dbee5c44f8e0eb855eb012842d87471005ee3c5e782014bc6ed8974250fd51"
    },
    {
      "name": "nested metadata and integer amount",
      "request": {
        "order_id": "order-777",
        "sats": 21000,
        "metadata": {
          "sku": "fruit-basket",
          "tier": 2,
          "gift": true
        }
      },
      "canonical_json": "{\"metadata\":{\"gift\":true,\"sku\":\"fruit-basket\",\"tier\":2},\"order_id\":\"order-777\",\"sats\":21000}",
      "expected_request_hash": "sha256:30ea57128027f273b4a3b89e4abf78c6dd8121ef81eebb40ba2cf5ad1c72e135"
    },
    {
      "name": "btc amount source",
      "request": {
        "order_id": "order-btc",
        "amount": {
          "btc": {
            "currency": "SATS",
            "value": "5000"
          }
        }
      },
      "canonical_json": "{\"amount\":{\"btc\":{\"currency\":\"SATS\",\"value\":\"5000\"}},\"order_id\":\"order-btc\"}",
      "expected_request_hash": "sha256:dde0f552c0c8c659d2eb47ab3f3e1e7f2a8edd1ef34c47e24fdbc3fc4bc8a547"
    }
  ]
}
