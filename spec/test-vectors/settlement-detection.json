{
  "schema_version": "0.1.0",
  "rule": "list_transactions settlement requires settled_at or state == settled; preimage alone is not final proof",
  "cases": [
    {
      "name": "settled by state",
      "transaction": {
        "state": "settled",
        "payment_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      },
      "expected": {
        "settled": true
      }
    },
    {
      "name": "settled by settled_at",
      "transaction": {
        "state": "pending",
        "settled_at": 1781740990,
        "payment_hash": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
      },
      "expected": {
        "settled": true
      }
    },
    {
      "name": "preimage alone is not settled",
      "transaction": {
        "state": "pending",
        "preimage": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
        "payment_hash": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
      },
      "expected": {
        "settled": false
      }
    },
    {
      "name": "expired is not settled",
      "transaction": {
        "state": "expired",
        "payment_hash": "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
      },
      "expected": {
        "settled": false
      }
    }
  ]
}
