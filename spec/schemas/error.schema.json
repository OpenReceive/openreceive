{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.openreceive.org/schemas/error.v1.json",
  "title": "OpenReceive Error",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code",
    "message"
  ],
  "properties": {
    "code": {
      "type": "string",
      "enum": [
        "NOT_IMPLEMENTED",
        "RESTRICTED",
        "UNAUTHORIZED",
        "RATE_LIMITED",
        "QUOTA_EXCEEDED",
        "INTERNAL",
        "UNSUPPORTED_ENCRYPTION",
        "INSUFFICIENT_BALANCE",
        "PAYMENT_FAILED",
        "OTHER",
        "NOT_FOUND",
        "TIMEOUT",
        "INVALID_REQUEST",
        "WALLET_UNAVAILABLE",
        "INVOICE_EXPIRED",
        "UNSUPPORTED_METHOD",
        "CONFLICT"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "retryable": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
