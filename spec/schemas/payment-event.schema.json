{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.openreceive.org/schemas/payment-event.v2.json",
  "title": "OpenReceive Verified Payment Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["paymentHash", "paidAt"],
  "properties": {
    "paymentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "paidAt": { "type": "integer", "minimum": 0 },
    "details": { "type": "object", "additionalProperties": true }
  }
}
