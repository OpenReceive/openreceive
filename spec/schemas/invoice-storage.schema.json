{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.openreceive.org/schemas/invoice-storage.v1.json",
  "title": "OpenReceive Invoice Storage Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "invoice_id",
    "namespace",
    "operation",
    "idempotency_key",
    "idempotency_request_hash",
    "payment_hash",
    "invoice",
    "amount_msats",
    "transaction_state",
    "workflow_state",
    "settlement_action_state",
    "created_at",
    "expires_at",
    "metadata"
  ],
  "properties": {
    "invoice_id": {
      "type": "string",
      "pattern": "^or_inv_[a-z0-9_]+$"
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": ["invoice.create", "invoice.renew"]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "idempotency_request_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "payment_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "invoice": {
      "type": "string",
      "minLength": 1
    },
    "amount_msats": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 9007199254740991
    },
    "transaction_state": {
      "type": "string",
      "enum": ["pending", "settled", "expired", "failed", "accepted"]
    },
    "workflow_state": {
      "type": "string",
      "enum": [
        "draft",
        "invoice_created",
        "verifying",
        "settlement_action_pending",
        "settlement_action_completed",
        "expiry_pending_verification",
        "expired_closed",
        "failed_closed",
        "cancelled"
      ]
    },
    "settlement_action_state": {
      "type": "string",
      "enum": ["pending", "completed", "failed"]
    },
    "created_at": {
      "type": "integer",
      "minimum": 0
    },
    "expires_at": {
      "type": "integer",
      "minimum": 0
    },
    "settled_at": {
      "type": "integer",
      "minimum": 0
    },
    "settlement_action_completed_at": {
      "type": "integer",
      "minimum": 0
    },
    "last_transaction_scan_at": {
      "type": "integer",
      "minimum": 0
    },
    "action_claimed_at": {
      "type": "integer",
      "minimum": 0
    },
    "refreshed_from_invoice_id": {
      "type": "string",
      "pattern": "^or_inv_[a-z0-9_]+$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "fiat_quote": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "$defs": {
    "StoredRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rev", "row"],
      "properties": {
        "rev": {
          "type": "integer",
          "minimum": 0
        },
        "row": {
          "$ref": "#"
        }
      }
    },
    "MetaRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "rev"],
      "properties": {
        "value": {
          "type": "string"
        },
        "rev": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "TransactionScanCursor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["until_cursor", "last_swept_at"],
      "properties": {
        "until_cursor": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "last_swept_at": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "x-openreceive-invariants": [
    "invoice_id is unique",
    "payment_hash is unique where present",
    "idempotency_key is unique within namespace + operation + idempotency_key",
    "same idempotency request hash returns original response",
    "different idempotency request hash returns 409",
    "local expires_at alone does not make a row terminal",
    "expired_closed requires wallet transaction finality",
    "settlement_action_completed_at can be set once",
    "last_transaction_scan_at records the most recent server-side status refresh scan attempt",
    "action_claimed_at records the store-coordinated settlement action lease",
    "renewal creates a new invoice row"
  ]
}
