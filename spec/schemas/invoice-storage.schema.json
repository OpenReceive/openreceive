{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.openreceive.org/schemas/invoice-storage.v1.json",
  "title": "OpenReceive Invoice Storage Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "invoice_id",
    "merchant_scope",
    "operation",
    "idempotency_key",
    "idempotency_request_hash",
    "payment_hash",
    "invoice",
    "amount_msats",
    "transaction_state",
    "workflow_state",
    "settlement_action_state",
    "created_at",
    "expires_at",
    "metadata"
  ],
  "properties": {
    "invoice_id": {
      "type": "string",
      "pattern": "^or_inv_[a-z0-9_]+$"
    },
    "merchant_scope": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": [
        "invoice.create",
        "invoice.refresh"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "idempotency_request_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "payment_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "invoice": {
      "type": "string",
      "minLength": 1
    },
    "amount_msats": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 9007199254740991
    },
    "transaction_state": {
      "type": "string",
      "enum": [
        "pending",
        "settled",
        "expired",
        "failed",
        "accepted"
      ]
    },
    "workflow_state": {
      "type": "string",
      "enum": [
        "draft",
        "invoice_created",
        "verifying",
        "settlement_action_pending",
        "settlement_action_completed",
        "expiry_pending_verification",
        "expired_closed",
        "failed_closed",
        "cancelled"
      ]
    },
    "settlement_action_state": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed"
      ]
    },
    "created_at": {
      "type": "integer",
      "minimum": 0
    },
    "expires_at": {
      "type": "integer",
      "minimum": 0
    },
    "settled_at": {
      "type": "integer",
      "minimum": 0
    },
    "settlement_action_completed_at": {
      "type": "integer",
      "minimum": 0
    },
    "refreshed_from_invoice_id": {
      "type": "string",
      "pattern": "^or_inv_[a-z0-9_]+$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "fiat_quote": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    }
  },
  "x-openreceive-invariants": [
    "invoice_id is unique",
    "payment_hash is unique where present",
    "idempotency_key is unique within merchant_scope + operation + idempotency_key",
    "same idempotency request hash returns original response",
    "different idempotency request hash returns 409",
    "local expires_at alone does not make a row terminal or remove it from recovery",
    "expired_closed requires post-expiry wallet lookup or exhausted post-expiry grace verification",
    "settlement_action_completed_at can be set once",
    "refresh creates a new invoice row"
  ]
}
